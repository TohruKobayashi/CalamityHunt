	Goozmaga: {
		DisplayName: Гузмастерство
		Tooltip:
			'''
			Бросает планеты, вращающиеся вокруг поражённого врага
			Попадание во врага, вокруг которого уже крутится планета, увеличивает её скорость
			Данный эффект складывается до 8 раз
			Скрытные удары создают два дополнительных планетоида, также вращающихся вокруг врага
			Нажмите <right>, чтобы уничтожить все существующие планеты и планетоиды
			'''
	}

	ShogunChestplate: {
		DisplayName: Нагрудник скользкого сёгуна
		Tooltip:
			'''
			Увеличивает урон на 20%
			Снижает получаемый урон на 9% и значительно ускоряет регенерацию здоровья
			Увеличивает максимальный запас здоровья и маны на 150
			'''
	}

	ShogunHelm: {
		DisplayName: Шлем скользкого сёгуна
		Tooltip:
			'''
			Увеличивает урон на 20%
			Увеличивает шанс критического удара на 15%
			Увеличивает скорость ближней атаки на 15%
			'''
		SetBonus:
			'''
			Увеличивает урон на 17% и максимальное количество миньонов на 5
			{$CommonItemTooltip.FlightAndSlowfall}
			Ношение других крыльев перекрывает данный полёт
			{$CommonItemTooltip.PressDownToHover}
			Позволяет делать рывок и совершенствует другие рывки
			Зажмите ВНИЗ, чтобы падать быстрее
			Увеличивает скорость прыжка 
			Даёт иммунитет к большинству дебаффов конца игры и дебаффам, связанным с передвижением
			'''
	}

	ShogunPants: {
		DisplayName: Штаны скользкого сёгуна
		Tooltip:
			'''
			Увеличивают урон на 20%
			Увеличивают скорость передвижения на 50%
			Значительно улучшают ускорение и манёвренность
			'''
	}

	AuricSole: {
		DisplayName: Ауритовая подушва
		Tooltip:
			'''
			Нажмите <right>, чтобы отключить 
			Позволяет скользить по любым поверхностям
			Осторожно: можно достичь неконтролируемо больших скоростей
			«Ярим бы возненавидел вас за это»
			'''
	}

