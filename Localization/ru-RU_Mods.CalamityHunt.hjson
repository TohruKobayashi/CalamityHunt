	PumpActionSwampgun: {
		DisplayName: Помповый болотовик
		Tooltip: Стреляет относительно безобидным всплеском слизи
	}

	Parasanguine: {
		DisplayName: Парасангвинник
		Tooltip:
			'''
			Пока вы держите <left> или наносите урон врагам, накапливаются излишки крови
			Нажмите <right>, когда шкала крови заполнена, чтобы выплеснуть излишки
			Нажмите <left> после выплеска крови, чтобы совершить разрушительный взмах
			«Что получается при кормёжке слизня? Слизень побольше»
			'''
	}

	Gobflogger: {
		DisplayName: Слизьтатель
		Tooltip:
			'''
			{$CommonItemTooltip.SummonTagDamage}
			{$CommonItemTooltip.Whips}
			Бейте противников, чтобы получить небольшой бонус к скорости атаки кнутом
			«Тише едешь, дальше будешь»
			'''
	}

	CrystalGauntlets: {
		DisplayName: Кристаллические перчатки
		Tooltip:
			'''
			Удерживайте <left>, чтобы собирать энергию, формируя мощный шар из молний
			Полностью сформировав шар, отпустите <left>, чтобы выпустить его на встречу своим противникам
			Нажмите <right>, чтобы хлопнуть в ладоши, взрывая все выпущенные шары из молний 
			«Безграничная власть!»
			'''
	}

	SplendorJam: {
		DisplayName: Варенье великолепия
		Tooltip:
			'''
			Активирует шкалу стресса
			Стресс постепенно накапливается, однако возле противников стресс накапливается быстрее
			Вы излучаете свет, сила которого зависит от уровня стресса
			При достижении 0%, 25%, 50%, 75%, и 100% стресса, дарует вам спец-такль
			При достижении 25% стресса, ваше оружие начнёт создавать взрывы
			При достижении 75% стресса, ваши взрывы становятся больше и сильнее
			Дважды нажмите ВНИЗ, пока уровень стресса выше 25%, чтобы войти в режим злобы
			Режим злобы значительно увеличивает ваш урон, а также даёт фиксированную прибавку к нему, пробиванию брони и шансу критического удара
			Бонусы и их длительность масштабируются с количеством вашего стресса
			«Близится что-то ужасное...»
			'''
		StressBar: Стресс: {0}
	}

	TheSlimer: {
		DisplayName: Слизневик
		Tooltip:
			'''
			Стреляет существенной суспензией слипающейся слизи
			Во время стрельбы слизь застревает, образуя пробку
			Нажмите <right>, пока орудие забито, чтобы выпустить желчную бомбу
			«Не путать со слизуном»
			'''
	}

	SludgeShaker: {
		DisplayName: Сотрясатель слякоти
		Tooltip:
			'''
			Стреляет существенной суспензией слипающейся слизи
			Во время стрельбы слизь прилипает к блокам и другим слизням
			«Взболтать, не размешивать»
			'''
	}

	SupremeRestorationPotion: {
		DisplayName: Омега зелье восстановления
		Tooltip: Снижено время перезарядки зелий
	}

	ChromaticTorch: {
		DisplayName: Хроматический факел
		Tooltip: ""
	}

	StickyHand: {
		DisplayName: Липко-мерзкая рука
		Tooltip:
			'''
			Автоматически отцепляется, когда вы достаточно близки к крюку
			Зажмите клавишу крюка, чтобы прикрепиться к блоку
			«Уверяю вас — она не порвётся»
			{$}
			'''
		Stats:
			'''
			Дальность: 56 блок(ов)
			Скорость крюка: 25
			Скорость возврата: 10
			Скорость притягивания: 17
			'''
	}

	Trailblazer: {
		DisplayName: Первопроходец
		Tooltip:
			'''
			Использует гель в качестве боеприпасов
			Игнорирует 30 ед. защиты врага
			Шанс 80% не потратить боеприпасы
			'''
	}

	SlimeCane: {
		DisplayName: Трость слизня
		Tooltip:
			'''
			Призывает команду из 4 слизней-оруженосцев защищать вас
			Повторное использование оружия усиливает слизней, занимая 1 ячейку миньона
			Слизней можно усилить до 4 раз
			Усилив команду слизней до максимума, призывает Гузмоэм, стреляющий термоядерными лучами
			«Если б я мог избавиться от всей грязи да сделать мир прекрасным, по моему образу и подобию»
			'''
	}

	FissionFlyer: {
		DisplayName: Расщепляющий резак
		Tooltip:
			'''
			Бросает шакрам, разделяющийся на 3 колких кольца
			Скрытные удары оставляют за собой огромный клинок
			'''
	}

	ScytheOfTheOldGod: {
		DisplayName: Коса старого бога
		Tooltip:
			'''
			Взмахивает огромной косой, разрезающей врагов тройным комбо
			«Не путать с Косой старого Герцога...
			...И ничем другим»
			'''
	}

	Goomoire: {
		DisplayName: Слизьмуар
		Tooltip:
			'''
			Колдует сковывающий вихрь, что всасывает в себя противников
			«Только не яма! Я ТАМ СГОРЮ!»
			'''
	}

	SlimeNinjaStatue: {
		DisplayName: Статуя ниндзя слизней
		Tooltip:
			'''
			Окружите 4 статуями слизня, а после воспользуйтесь желейным катализатором, чтобы вызвать дождь из слизней
			Значительно ускоряет сбор слизней при активации
			«А это кто вообще такой?»
			'''
	}

	GelatinousCatalyst: {
		DisplayName: Желейный катализатор
		Tooltip: Tooltip: Используйте на усиленной статуе ниндзя слизней, чтобы вызвать дождь из слизней
	}

	PluripotentSpawnEgg: {
		DisplayName: Плюрипотентное яйцо призыва
		Tooltip:
			'''
			Используйте на усиленной статуе ниндзя слизней, чтобы призвать что-то ужасающее
			Не расходуется
			'''
	}

	PaladinPalanquin: {
		DisplayName: Паланкин паладина
		Tooltip:
			'''
			Призывает ездовой масляной шарик
			«Почувствуйте себя императором!»
			'''
	}

	ChromaticBomb: {
		DisplayName: Хроматическая бомба
		Tooltip: Бросает игнорирующую гравитацию чёрную дыру, уничтожающую блоки
	}

	ChromaticGooztick: {
		DisplayName: Хроматическая светящаяся липалка
		Tooltip: Игнорирует гравитацию и отскакивает от блоков
	}

	DynamoRod: {
		DisplayName: Динамо динамит
		Tooltip: Взрывается в виде огромной, разрушающей блоки чёрной дыры
	}

	BadApple: {
		DisplayName: Плохое яблоко
		Tooltip:
			'''
			«Яблоко, упавшее с древа, что пострадало от очередной вспышки ярости Гузмы.
			По виду фрукт перевоплотился во что-то относительно новое, скорее всего ужасное на вкус.
			Но если на вкус яблочко всё же покажется нормальным — запах вас расстроит...»
			'''
	}

	CometKunai: {
		DisplayName: Кометный кунай
		Tooltip:
			'''
			Выпускает шквал из кунаев и звёзд, создающих собственные копии при успешном попадании
			Скрытные удары вызывают звёздный дождь при попадании
			«Мощь звёзд у меня в руках...»
			'''
	}

	GoopHairDye: {
		DisplayName: Склизкая краска для волос
		Tooltip: ""
	}

	AntiMassAccumulator: {
		DisplayName: Аккумулятор анти-массы
		Tooltip:
			'''
			Выстреливает шарами сгруппированных протонов и болтами заряженных электронов друг за другом
			Шары протонов заряжают всё, чего касаются и могут наносить урон врагам в определённом радиусе
			Болты электронов наносят дополнительный урон положительно заряженным врагам
			«Не смотрите непосредственно на рабочий конец устройства.»
			'''
	}

	GoozmaBoulderItem: {
		DisplayName: Пёстрый шарик
		Tooltip: «Чрезвычайно опасен»
	}

