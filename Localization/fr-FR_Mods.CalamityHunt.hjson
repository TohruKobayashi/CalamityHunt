	Goozmaga: {
		DisplayName: Goozmaga
		Tooltip:
			'''
			         Lance une planète qui orbite les ennemis touchés
			         Si un ennemi a déjà une planète l'orbitant, celle ci gagnera en vitesse
			Cet effet peut s'accumuler jusqu'à 8 fois
			         Les frappes furtives rajoutent deux planètoides en plus pour orbiter la cible
			<right> pour faire disparaitre toutes les planètes et planètoides existants
			'''
	}

	ShogunChestplate: {
		DisplayName: Plastron de shogun visqueux
		Tooltip:
			'''
			+20% de dégats
			Reduces damage taken by 9% and greatly increases life regeneration
			         +150 de vie et de mana maximum
			'''
	}

	ShogunHelm: {
		DisplayName: Casque de shogun visqueux
		Tooltip:
			'''
			+20% de dégats
			+15% de chances de coup critique
			+15% de vitesse de mêlée
			'''
		SetBonus:
			'''
			+ 17% de dégats et +5 sbires maximum
			{$CommonItemTooltip.FlightAndSlowfall}
			{$CommonItemTooltip.PressDownToHover}
			Avoir des ailes déjà équipées nullifie cet effet
			   Vous permet de foncer dans les enemis, et améliore les autres charges
			Maintenez BAS enfoncé pour augmenter votre vitesse de chute
			Augmente la vitesse de saut
			   Immunise contre la plupart des alterations de fin de jeu et celles liées au mouvement
			'''
	}

	ShogunPants: {
		DisplayName: Pantalons de shogun visqueux
		Tooltip:
			'''
			+20% de dégats
			+50% de vitesse de déplacement
			         Augmente grandement l'accélération et la mobilité
			         
			'''
	}

	AuricSole: {
		DisplayName: Semelle Aurique
		Tooltip:
			'''
			<right> pour désactiver
			         Permet de glisser sur toutes les surfaces
			         Attention! Peut amener à des vitesses dangeureusement élevées
			'Yharim ne te pardonerais jamais ça si il savait'
			'''
	}

	DischargedAuricSole: {
