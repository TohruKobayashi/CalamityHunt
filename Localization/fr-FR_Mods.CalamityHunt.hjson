	StellarGeliathTrophy: {
		DisplayName: Trophée du Geliath Stellaire
		Tooltip: ""
	}

	PumpActionSwampgun: {
		DisplayName: Fusil Pompe-Bourbe
		Tooltip: Éjacule une gerbe relativement inoffensive de gelée
	}

	Parasanguine: {
		DisplayName: Parasanguine
		Tooltip:
			'''
			Tenir <left> enfoncé, ou toucher des ennemis accumule un excès de sang
			<right> quand la barre de sang est pleine pour expulser l'excès
			<left> après un clic droit performera un tournoiement devastateur
			'Qu'obtiens-tu en nourissant un slime? Un plus grand slime.'
			'''
	}

	Gobflogger: {
		DisplayName: Boufouet
		Tooltip:
			'''
			{$CommonItemTooltip.SummonTagDamage}
			{$CommonItemTooltip.Whips}
			Frappez des ennemis pour gagner un petit peu de vitesse d'attaque au fouet
			'Lentement, mais surement...'
			'''
	}

	CrystalGauntlets: {
		DisplayName: Gantelets de cristal
		Tooltip:
			'''
			Maintenez <left> appuyé pour charger une puissante boule de foudre
			Quand la charge est pleine, relâchez <left> pour envoyer la balle de foudre sur vos ennemis
			<right> pour applaudir, détonant toutes les boules de foudre
			'Puissance illimitée!!!'
			'''
	}

	SplendorJam: {
		DisplayName: Confiture resplentissante
		Tooltip:
			'''
			         Active la barre de stress
			         Le Stress s'accumule passivement, mais être proche d'un enemi accélére la vitesse à laquelle il augmente
			         Vous produisez plus ou moins de lumière en accordance avec votre niveau de Stress
			         Produits un miracle à 25%, 50%, 75% et 100% de Stress
			A 25% de Stress, vos armes produiront des explosions
			A 75% de Stress, les explosions seront plus grandes et feront plus de dégats
			Effectuez un double clic sur ▼ Bas quand le stress est au dessus de 25% pour entrer en mode Malicieux
			         En mode Malicieux, vos dégats augmentent beaucoup, et vous recevez encore des dégats plats, chance de coup critique, et pénétration d'armure
			         Ces augmentations et leur duration dependent de votre quantité de stress
			'Quelque chose d'horrible approche...'
			'''
		// StressBar: Stress: {0}
	}

	SludgeShaker: {
		DisplayName: Mixeur de glue
		Tooltip:
			'''
			         Produits une grande gerbe de vase collante
			         La vase colle aux structures lorsqu'il est aspergé
			'Bon appétit!'
			'''
	}

	SupremeRestorationPotion: {
		DisplayName: Omega potion de restauration
		Tooltip: Temps de rafraîchissement réduit
	}

	ChromaticTorch: {
		DisplayName: Torche chromatique
		Tooltip: ""
	}

	StickyHand: {
		DisplayName: Main gluante
		Tooltip:
			'''
			         Vous détache automatiquement quand le grappin est atteint
			         Gardez le bouton appuyé pour garder le grappin attaché
			'Ca se cassera pas, j'te JURE!'
			'''
		Stats:
			'''
			Portée: 56
			Vitesse de lancer: 25
			Vitesse de retraction: 10
			Vitesse de traction: 17
			'''
	}

	Trailblazer: {
		DisplayName: L'attiseur de braises
		Tooltip:
			'''
			Utilise du gel comme munitions
			         Ignore 15 points de la défense ennemie
			80% de chances d’économiser des munitions
			'''
	}

	SlimeCane: {
		DisplayName: Cane de gelée
		Tooltip:
			'''
			         Invoque un groupe de 4 écuyers visqueux pour vous combattre à vos côtés
			Utiliser la cane encore une fois améliore les écuyers existants
			         Les écuyers peuvent être améliorés un maximum de 4 fois
			         Après avoir amélioré les gelées au maximum, un Goozmœuf apparaîtra, utilisant un rayon de fusion contre vos ennemis
			'Si seulement je pouvais éliminer les impurités et le rendre aussi beau que moi'
			'''
	}

	FissionFlyer: {
		DisplayName: Disque à fission
		Tooltip:
			'''
			         Lance un chakram qui se divise en 3 anneaux-rasoir
			         Les frappes furtives se divisent en encore plus d'anneaux et laissent derrière elles une lame colossale
			'''
	}

	ScytheOfTheOldGod: {
		DisplayName: Faux de l'Ancien Dieu
		Tooltip:
			'''
			Balance une faux colossale dans un combo en trois temps
			'A ne pas confondre avec la faux de l'Ancien Duc...
			...et rien d'autre du tout.'
			'''
	}

	Goomoire: {
		DisplayName: Goomoire
		Tooltip:
			'''
			         Jette un sort de bannissement qui absorbe les ennemis
			'Pas dans la fosse ! Ca brûle!'
			'''
	}

	SlimeNinjaStatue: {
		DisplayName: Statue du ninja visqueux
		Tooltip:
			'''
			         Entourez la de 4 statues de gelées et interagissez avec un catalyste gélatineux pour amener une pluie de gelée
			'De toute façon, c'est qui ce type?'
			'''
	}

	GelatinousCatalyst: {
		DisplayName: Catalsyte gélatineux
		Tooltip: Utiliser cela sur une statue de ninja visqueux entourée de 4 statues de gelée pour amener une pluie de gelée
	}

	PluripotentSpawnEgg: {
		DisplayName: Œuf pluripotent
		Tooltip:
			'''
			Utiliser cela sur une statue de ninja visqueux entourée de 4 statues de gelée invoquer directement Goozma
			Non consumable
			'''
	}

	PaladinPalanquin: {
		DisplayName: Palanquin de paladin
		Tooltip:
			'''
			         Invoque une bulle d'huile à chevaucher
			'On se sent comme un roi!'
			'''
	}

	ChromaticGooztick: {
		DisplayName: Dynamite chromatique
		Tooltip: Ignore la gravité et rebondis contre les blocs
	}

	BadApple: {
		DisplayName: Bad Apple
		Tooltip:
			'''
			         Une pomme provenant d'un arbre annihilé lors du combat contre Goozma.
			         Il semble s'être transformé en quelque chose de nouveau, et donc a probablement un goût terrible.
			         En tout cas, si le goût n'est pas étrange, l'odeur l'est certainement...
			'''
	}

	CometKunai: {
		DisplayName: Kunai comète
		Tooltip:
			'''
			         Envoie un torrent de kunais et d'étoiles, redoublés lorsque vous frappez des ennemis
			Les frappes furtives provoquent une pluie d'étoiles partout où elles atterissent
			'Le pouvoir des étoiles, dans la paume de ma main...'
			'''
	}

