Items: {
	OverloadedSludge: {
		DisplayName: Gelatine concentrée
		Tooltip:
			'''
			Invoque le dieu des gelées
			Pas consumable
			'Elle a un air corrompu'
			'''
		// Warning: Cannot be used to summon the Slime God
	}

	GoopDye: {
		DisplayName: Teinture visqueuse
		Tooltip: ""
	}

	ChromaticMass: {
		DisplayName: Amas chromatique
		Tooltip: "'Semblable a un plasme glacial'"
	}

	GoozmaRelic: {
		// DisplayName: Goozma Relic
		// Tooltip: ""
	}

	GoozmaLore: {
		DisplayName: Goozma
		Lore:
			'''
			Un bouleversement des plus effrayants, dans le domaine hiérarchique de toutes choses vivantes.
			Se dire que l’aboutissement de l’échelon le plus bas des créatures pourrait néanmoins posséder une âme aurique, malgré l’absence de tout héritage draconique…
			C'est devenu quelque chose de plus grand, proche d'un être parfait composé uniquement de parties imparfaites... peut-être que ce qui fait réellement un Dieu sera à jamais inconnu.
			Mon appréhension à l’égard de votre catalyse de la culture de ce véritable signe avant-coureur de la destruction est contrebalancée par ma curiosité à son égard.
			Qu’est-ce qui a pu influencer la forme qu’il a prise ? Son apparence cache la finesse et la sophistication de la manipulation de ses sujets.
			Quel dommage que les fruits de ses efforts n’aient finalement abouti à rien. Un modèle incessant dans les annales cycliques de l’histoire.
			Peut-être que, du point de vue de Terraria, nos propres réalisations ne se résument qu’à des contorsions impuissantes d'une gelée.
			'''
		Tooltip: ""
	}

	TreasureTrunk: {
		DisplayName: Cache à trésor
